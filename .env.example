# Configuration API Backend
# URL de base de l'API FastAPI
NUXT_PUBLIC_API_BASE=http://localhost:8000
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# URL publique du site (utilisée pour les balises OG meta, sitemap, etc.)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# En production, remplacer par l'URL réelle de votre API
# NUXT_PUBLIC_API_BASE=https://api.usenghor.com
# NUXT_PUBLIC_API_BASE_URL=https://api.usenghor.com
# NUXT_PUBLIC_SITE_URL=https://usenghor-francophonie.org
